# Copy to .env and fill in real values. .env is gitignored — never commit it.
# worker.py loads this automatically (see scripts/worker.py); a real
# `export`ed environment variable always takes precedence over this file.

# Required only if config.yaml has wavespeed.enabled: true
WAVESPEED_API_KEY=

# Required only if config.yaml has telegram.enabled: true (the FR-4 approval
# loop). Create a bot via @BotFather in Telegram — no business verification
# needed, unlike WhatsApp Business API.
TELEGRAM_BOT_TOKEN=
